# Logging
# Available levels: trace, debug, info, warn, error, fatal
ELECTRON_MCP_LOG_LEVEL=info

# Maximum number of concurrent Electron sessions
ELECTRON_MCP_MAX_SESSIONS=5

# Default timeout (ms) for launching Electron apps
ELECTRON_MCP_LAUNCH_TIMEOUT=30000

# Default timeout (ms) for renderer-side operations (click, fill, waitFor)
ELECTRON_MCP_ACTION_TIMEOUT=15000

# Default timeout (ms) for evaluate calls (renderer + main process)
ELECTRON_MCP_EVALUATE_TIMEOUT=10000

# Comma-separated glob patterns. Only executables matching one of these patterns
# are allowed to be launched. Empty string disables the allowlist (dev only!).
# Example: /Applications/*.app/**,/usr/local/bin/*
ELECTRON_MCP_EXECUTABLE_ALLOWLIST=

# Whether to allow evaluation on the Electron main process ("true" or "false").
# The main process has full Node.js access - keep this disabled unless trusted.
ELECTRON_MCP_ALLOW_MAIN_EVALUATE=false

# Screenshot storage directory (created if missing)
ELECTRON_MCP_SCREENSHOT_DIR=./screenshots

# Transport: "stdio" (default) or "http"
ELECTRON_MCP_TRANSPORT=stdio

# When using HTTP transport
ELECTRON_MCP_HTTP_PORT=7337
ELECTRON_MCP_HTTP_HOST=127.0.0.1
